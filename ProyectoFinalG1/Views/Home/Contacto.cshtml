@model ProyectoFinalG1.Models.HomeModel
@{
    ViewBag.Title = "Contacto";
}

<section id="contact-banner" style="background: #F9F3EC;">
    <div class="container py-5">
        <div class="row align-items-center py-5">
            <div class="col-md-6">
                <div class="secondary-font text-primary text-uppercase mb-3">
                    Estamos para ayudarte
                </div>
                <h1 class="display-2 fw-normal mb-4">
                    Contáctanos en <span class="text-primary">Waggy</span>
                </h1>
                <p class="fs-5 text-muted">
                    Si tienes consultas sobre productos, pedidos o disponibilidad,
                    puedes comunicarte con nosotros por cualquiera de nuestros canales.
                </p>
            </div>
            <div class="col-md-6 text-center">
                <img src="~/Template/images/banner-img4.png" class="img-fluid rounded-4" alt="Contacto Waggy">
            </div>
        </div>
    </div>
</section>

<section id="contact-info">
    <div class="container py-5 my-5">
        <div class="row g-4 justify-content-center">

            <!-- Teléfonos -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4 text-center">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:phone-outline"></iconify-icon>
                    <h4>Teléfonos</h4>
                    <p class="mb-1">+506 2222-3333</p>
                    <p class="mb-0">+506 8888-9999</p>
                </div>
            </div>

            <!-- Correo -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4 text-center">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:email-outline"></iconify-icon>
                    <h4>Correo</h4>
                    <p class="mb-0">contacto@waggy.com</p>
                </div>
            </div>

            <!-- Horario -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4 text-center">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:clock-outline"></iconify-icon>
                    <h4>Horario</h4>
                    <p class="mb-1">Lunes a Viernes: 8:00 a.m. - 6:00 p.m.</p>
                    <p class="mb-0">Sábados: 9:00 a.m. - 4:00 p.m.</p>
                </div>
            </div>

        </div>
    </div>
</section>

<section id="location" style="background: #F9F3EC;">
    <div class="container py-5 my-5">
        <div class="row align-items-center g-5">

            <!-- Info -->
            <div class="col-md-5">
                <div class="secondary-font text-primary text-uppercase mb-3">
                    Ubicación
                </div>
                <h2 class="display-4 fw-normal mb-4">Visítanos</h2>

                <p class="blog-paragraph fs-5">
                    Nos encontramos en una ubicación accesible para brindarte una mejor atención
                    y ayudarte a encontrar todo lo que tu mascota necesita.
                </p>

                <div class="mt-4">
                    <p class="mb-2"><strong>Dirección:</strong></p>
                    <p class="mb-3">
                        San José, Costa Rica, Avenida Central, Calle 10
                    </p>

                    <p class="mb-2"><strong>Teléfono:</strong></p>
                    <p class="mb-3">+506 2222-3333</p>

                    <p class="mb-2"><strong>Correo:</strong></p>
                    <p class="mb-0">contacto@waggy.com</p>
                </div>
            </div>

            <!-- Mapa -->
            <div class="col-md-7">
                <div class="rounded-4 overflow-hidden shadow-sm">
                    <iframe src="https://www.google.com/maps?q=San+José+Costa+Rica&output=embed"
                            width="100%"
                            height="400"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy">
                    </iframe>
                </div>
            </div>

        </div>
    </div>
</section>

<section id="contact-cta">
    <div class="container py-5 my-5 text-center">
        <h2 class="display-5 fw-normal mb-3">
            Estamos aquí para ayudarte
        </h2>
        <p class="fs-5 text-muted mb-4">
            Contáctanos y con gusto te asesoramos en todo lo que necesites para tu mascota.
        </p>
    </div>
</section>