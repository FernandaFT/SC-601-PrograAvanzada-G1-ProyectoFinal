@model ProyectoFinalG1.Models.UsuarioModel

@{
    Layout = "~/Views/Shared/_LayoutInicioSesionRegistro.cshtml";
}

<section class="register" id="register"
         style="background: url('@Url.Content("~/Template/images/background-img.png")') center / cover no-repeat;">

    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-12 col-md-10 col-lg-8 col-xl-6">

                <div class="text-box mt-5 mb-5 text-center">
                    <h1 class="mb-4 banner-title display-1 fw-normal text-primary">Registro</h1>
                    <p class="mb-4 blog-paragraph fs-6">
                        Completa el siguiente formulario para registrarte en Waggy.
                        <br />¿Ya tienes una cuenta?
                        <a class="blue" href="@Url.Action("InicioSesion", "Home")">Inicia sesión</a>
                    </p>

                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger text-center">
                            @ViewBag.Mensaje
                        </div>
                    }

                    @using (Html.BeginForm("Registro", "Home", FormMethod.Post, new { @id = "FormRegistro" }))
                    {
                        <div class="mb-4 form-floating">
                            @Html.TextBoxFor(m => m.Identificacion, new { @placeholder = "Identificación", @class = "form-control no-transform" })
                            <label>Identificación</label>
                        </div>
                        <div class="mb-4 form-floating">
                            @Html.TextBoxFor(m => m.Nombre, new { @placeholder = "Nombre", @class = "form-control no-transform" })
                            <label>Nombre</label>
                        </div>
                        <div class="mb-4 form-floating">
                            @Html.TextBoxFor(m => m.Correo, new { @placeholder = "Correo", @class = "form-control no-transform" })
                            <label>Correo Electrónico</label>
                        </div>
                        <div class="mb-4 form-floating">
                            @Html.TextBoxFor(m => m.Password, new { @type = "password", @placeholder = "Contraseña", @class = "form-control no-transform" })
                            <label>Contraseña</label>
                        </div>
                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-pill">
                            Registrarme
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script src="~/Template/js/funciones/registro.js"></script>