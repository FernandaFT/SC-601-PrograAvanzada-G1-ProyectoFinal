@model ProyectoFinalG1.Models.HomeModel
@{
    ViewBag.Title = "Sobre Nosotros";
}

<section id="about-banner" style="background: #F9F3EC;">
    <div class="container py-5">
        <div class="row align-items-center py-5">
            <div class="col-md-6">
                <div class="secondary-font text-primary text-uppercase mb-3">
                    Conoce nuestra historia
                </div>
                <h1 class="display-2 fw-normal mb-4">
                    Sobre <span class="text-primary">Waggy</span>
                </h1>
                <p class="fs-5 text-muted">
                    En Waggy creemos que las mascotas no son solo animales de compañía,
                    son parte de la familia. Por eso trabajamos cada día para ofrecer
                    productos de calidad, atención cercana y una experiencia de compra
                    pensada para quienes aman y cuidan a sus peluditos.
                </p>
            </div>
            <div class="col-md-6 text-center">
                <img src="~/Template/images/banner-img.png" class="img-fluid rounded-4" alt="Sobre Waggy">
            </div>
        </div>
    </div>
</section>

<section id="our-story">
    <div class="container py-5 my-5">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center mb-5">
                <h2 class="display-4 fw-normal">Nuestra Historia</h2>
                <p class="text-muted fs-5">
                    Una idea nacida del amor por las mascotas
                </p>
            </div>
        </div>

        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <img src="~/Template/images/insta3.jpg" class="img-fluid rounded-4 shadow-sm" alt="Historia de Waggy">
            </div>
            <div class="col-md-6">
                <p class="blog-paragraph fs-5">
                    Waggy nació con el propósito de crear un espacio donde los dueños de mascotas
                    pudieran encontrar en un solo lugar todo lo necesario para su bienestar:
                    alimentos, ropa y accesorios cuidadosamente seleccionados.
                </p>

                <p class="blog-paragraph fs-5">
                    La idea surgió al identificar que muchas veces las personas debían buscar en
                    distintos lugares para conseguir productos confiables y adecuados para sus
                    perros y gatos. A partir de esa necesidad, Waggy comenzó como un proyecto
                    enfocado en brindar comodidad, confianza y variedad.
                </p>

                <p class="blog-paragraph fs-5">
                    Con el tiempo, la empresa fue creciendo gracias a una visión clara:
                    ofrecer productos que aporten al cuidado, comodidad y felicidad de cada mascota,
                    acompañados de una atención cercana y una experiencia amigable para cada cliente.
                </p>
            </div>
        </div>
    </div>
</section>

<section id="mission-vision" style="background: #F9F3EC;">
    <div class="container py-5 my-5">
        <div class="row g-4 justify-content-center">

            <div class="col-md-5">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                    <div class="mb-3">
                        <iconify-icon class="service-icon text-primary" icon="mdi:target"></iconify-icon>
                    </div>
                    <h3 class="card-title">Misión</h3>
                    <p class="card-text blog-paragraph fs-6">
                        Brindar a nuestros clientes una tienda confiable y accesible,
                        con productos de calidad para mascotas, promoviendo su bienestar,
                        cuidado y felicidad a través de una atención cálida y eficiente.
                    </p>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                    <div class="mb-3">
                        <iconify-icon class="service-icon text-primary" icon="mdi:eye-outline"></iconify-icon>
                    </div>
                    <h3 class="card-title">Visión</h3>
                    <p class="card-text blog-paragraph fs-6">
                        Ser una tienda reconocida por su innovación, calidad y compromiso
                        con el bienestar animal, convirtiéndonos en una de las primeras
                        opciones para los amantes de las mascotas.
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<section id="values">
    <div class="container py-5 my-5">
        <div class="text-center mb-5">
            <h2 class="display-4 fw-normal">Nuestros Valores</h2>
            <p class="text-muted fs-5">Lo que define la esencia de Waggy</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-3">
                <div class="card h-100 border-0 text-center p-4 rounded-4 shadow-sm">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:heart-outline"></iconify-icon>
                    <h4>Amor por las mascotas</h4>
                    <p class="blog-paragraph fs-6">
                        Todo lo que hacemos está inspirado en el cuidado y bienestar de los animales.
                    </p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 text-center p-4 rounded-4 shadow-sm">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:shield-check-outline"></iconify-icon>
                    <h4>Calidad</h4>
                    <p class="blog-paragraph fs-6">
                        Seleccionamos productos confiables para ofrecer seguridad y satisfacción.
                    </p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 text-center p-4 rounded-4 shadow-sm">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:account-group-outline"></iconify-icon>
                    <h4>Compromiso</h4>
                    <p class="blog-paragraph fs-6">
                        Nos esforzamos por brindar una experiencia cercana, responsable y útil.
                    </p>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 text-center p-4 rounded-4 shadow-sm">
                    <iconify-icon class="service-icon text-primary mb-3" icon="mdi:lightbulb-on-outline"></iconify-icon>
                    <h4>Innovación</h4>
                    <p class="blog-paragraph fs-6">
                        Buscamos constantemente nuevas formas de mejorar nuestro servicio.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="why-waggy" style="background: #F9F3EC;">
    <div class="container py-5 my-5">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <div class="secondary-font text-primary text-uppercase mb-3">
                    ¿Por qué elegirnos?
                </div>
                <h2 class="display-4 fw-normal mb-4">
                    Más que una tienda, somos parte del cuidado de tu mascota
                </h2>
                <p class="blog-paragraph fs-5">
                    En Waggy queremos facilitar la vida de quienes buscan lo mejor para sus mascotas.
                    Por eso reunimos variedad, calidad y atención personalizada en un mismo lugar.
                </p>
                <p class="blog-paragraph fs-5">
                    Nuestro compromiso es ayudarte a encontrar productos que aporten bienestar,
                    comodidad y alegría a cada compañero de cuatro patas.
                </p>
            </div>

            <div class="col-md-6">
                <img src="~/Template/images/insta5.jpg" class="img-fluid rounded-4 shadow-sm" alt="Por qué elegir Waggy">
            </div>
        </div>
    </div>
</section>

<section id="team-quote">
    <div class="container py-5 my-5">
        <div class="row justify-content-center">
            <div class="col-lg-9 text-center">
                <iconify-icon icon="ri:double-quotes-l" class="quote-icon text-primary mb-4"></iconify-icon>
                <p class="fs-2">
                    En Waggy trabajamos con la convicción de que cada mascota merece amor,
                    cuidado y productos que mejoren su calidad de vida.
                </p>
                <p class="text-black fs-5">- Equipo Waggy</p>
            </div>
        </div>
    </div>
</section>