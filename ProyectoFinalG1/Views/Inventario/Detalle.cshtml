@model List<ProyectoFinalG1.Models.InventarioDetViewModel>

@{
    ViewBag.Title = "Detalle Inventario";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Detalle Inventario</h2>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @using (Html.BeginForm("GuardarDetalle", "Inventario", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <input type="hidden" name="inventarioId" value="@ViewBag.InventarioId" />

        <table class="table table-hover table-bordered shadow-sm">
            <thead class="thead-dark">
                <tr>
                    <th>Producto</th>
                    <th>Imagen</th>
                    <th>Stock Actual</th>
                    <th>Cantidad Contada</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NombreProducto</td>
                        <td>
                            <img src="@item.Imagen" alt="imagen" width="70" height="70" style="object-fit:cover;" />
                        </td>
                        <td>@item.StockActual</td>
                        <td>
                            <input type="number"
                                   name="cantidades[@item.ConsProducto]"
                                   value="@item.CantidadInventario"
                                   class="form-control"
                                   min="0" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-center mt-5 mb-5">
            <button type="submit" class="btn btn-success">
                Actualizar Inventario
            </button>

            <a href="@Url.Action("Eliminar", "Inventario", new { id = ViewBag.InventarioId })"
               class="btn btn-danger ms-2">
                Eliminar Inventario
            </a>

            <a href="@Url.Action("AplicarInventario", "Inventario", new { id = ViewBag.InventarioId })"
               class="btn btn-warning ms-2">
                Aplicar Inventario
            </a>
        </div>
    }
</div>