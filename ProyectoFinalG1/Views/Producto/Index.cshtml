@model List<ProyectoFinalG1.Models.ProductoModel>

@{
    ViewBag.Title = "Gestión de Productos";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Gestión de Productos</h2>
        <a href="@Url.Action("Crear", "Producto")" class="btn btn-primary">
            <i class="fa fa-plus"></i> Crear Nuevo Producto
        </a>
    </div>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Imagen</th>
                <th>Precio</th>
                <th>Unidad</th>
                <th>Existencia</th>
                <th>Mínimo</th>
                <th>Máximo</th>
                <th>Categoría</th>
                <th>Tipo Mascota</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.ConsecutivoProducto</td>
                    <td>@p.NombreProducto</td>
                    <td>
                        <img src="@p.Imagen" alt="imagen" width="70" height="70" style="object-fit:cover;" />
                    </td>
                    <td>₡ @p.Precio.ToString("N2")</td>
                    <td>@p.UnidadMedida.ToUpper()</td>
                    <td>@p.Existencia</td>
                    <td>@p.ExistenciaMin</td>
                    <td>@p.ExistenciaMax</td>
                    <td>@p.NombreCategoria</td>
                    <td>@p.TipoMascota</td>
                    <td>@(p.Estado ? "Activo" : "Inactivo")</td>

                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Editar", "Producto", new { id = p.ConsecutivoProducto })"
                               class="btn btn-warning btn-sm">Editar</a>

                            <a href="@Url.Action("CambiarEstado", "Producto", new { id = p.ConsecutivoProducto })"
                               class="btn @(p.Estado ? "btn-danger" : "btn-success") btn-sm"
                               title="@(p.Estado ? "Inactivar" : "Activar")">
                                <i class="fa @(p.Estado ? "fa-times" : "fa-check")"></i>
                                @(p.Estado ? "Inactivar" : "Activar")
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPaginas > 1)
    {
        <nav aria-label="Paginación de productos">
            <ul class="pagination justify-content-center">

                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Producto", new { pagina = paginaActual - 1 })">
                        Anterior
                    </a>
                </li>

                @for (int i = 1; i <= totalPaginas; i++)
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Producto", new { pagina = i })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Producto", new { pagina = paginaActual + 1 })">
                        Siguiente
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>