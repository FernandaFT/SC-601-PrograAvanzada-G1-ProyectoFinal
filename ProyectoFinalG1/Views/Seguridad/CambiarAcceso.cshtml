@model ProyectoFinalG1.Models.CambiarAccesoModel

@{
	ViewBag.Title = "Cambiar Acceso";
}

<div class="container mt-5 mb-5">
	<div class="card shadow p-4">
		<h2>Cambiar Contraseña</h2>

		@if (ViewBag.Error != null)
		{
			<div class="alert alert-danger">
				@ViewBag.Error
			</div>
		}
		@Html.ValidationSummary(true, "", new { @class = "text-danger-form" })

		@using (Html.BeginForm("CambiarAcceso", "Seguridad", FormMethod.Post))
		{
			@Html.AntiForgeryToken()
			<div class="row mt-3">
				<div class="col-md-6 form-group">
					<label>Contraseña Nueva</label>
					@Html.PasswordFor(m => m.ContrasennaNueva, new { @placeholder = "Contraseña nueva" })
					@Html.ValidationMessageFor(m => m.ContrasennaNueva, "", new { @class = "text-danger-form" })
				</div>
			
				<div class="col-md-6 form-group">
					<label>Confirmar Contraseña</label>
					@Html.PasswordFor(m => m.ConfirmarContrasenna, new { @placeholder = "Confirmar contraseña" })
					@Html.ValidationMessageFor(m => m.ConfirmarContrasenna, "", new { @class = "text-danger-form" })
				</div>
			</div>
			<div class="mt-4">
				<button type="submit" class="btn btn-success">
					<i class="fa fa-save"></i> Actualizar Contraseña
				</button>
			</div>
		}
	</div>
</div>
