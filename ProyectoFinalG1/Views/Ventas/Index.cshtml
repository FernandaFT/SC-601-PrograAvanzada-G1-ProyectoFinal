@model List<ProyectoFinalG1.Models.VentasModel>

@{
    ViewBag.Title = "Reporte de Ventas";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
    
}
}

<div class="container mt-4">

    <h2>Reporte de Ventas</h2>

    <form method="post" class="mb-3">
        <div class="row">

            <div class="col-md-3">
                <label>Fecha Inicio</label>
                <input type="date" name="FechaInicio" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Fecha Fin</label>
                <input type="date" name="FechaFin" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Cliente</label>
                @Html.DropDownList("IdUsuario", ViewBag.Usuarios as List<SelectListItem>, "Todos", new { @class = "form-control" })
            </div>

            <div class="col-md-3">
                <label>Producto</label>
                @Html.DropDownList("IdProducto", ViewBag.Productos as List<SelectListItem>, "Todos", new { @class = "form-control" })
            </div>

            <div class="col-md-3 mt-2">
                <button type="submit" class="btn btn-primary">Buscar</button>
            </div>

        </div>
    </form>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Producto</th>
                <th>Cantidad</th>
                <th>Total Línea</th>
                <th>Total Venta</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.ConsecutivoVenta</td>
                    <td>@v.FechaVenta.ToShortDateString()</td>
                    <td>@v.NombreCliente</td>
                    <td>@v.NombreProducto</td>
                    <td>@v.Cantidad</td>
                    <td>@v.MontoLinea</td>
                    <td>@v.MontoTotal</td>
                </tr>
            }
        </tbody>
    </table>
    @if (totalPaginas > 1)
    {
        <nav aria-label="Paginación de usuarios">
            <ul class="pagination justify-content-center">

                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Ventas", new { pagina = paginaActual - 1 })">
                        Anterior
                    </a>
                </li>

                @for (int i = 1; i <= totalPaginas; i++)
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Ventas", new { pagina = i })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Ventas", new { pagina = paginaActual + 1 })">
                        Siguiente
                    </a>
                </li>

            </ul>
        </nav>
    }

</div>