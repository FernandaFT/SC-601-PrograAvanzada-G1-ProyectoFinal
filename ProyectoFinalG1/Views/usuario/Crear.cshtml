@model ProyectoFinalG1.Models.UsuarioModel

@{
    ViewBag.Title = "Crear Usuario";
}

<div class="container mt-5 mb-5">
    <div class="card shadow p-4">
        <h2>Crear Usuario</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">
                @ViewBag.Error
            </div>
        }
        @Html.ValidationSummary(true, "", new { @class = "text-danger-form" })

        @using (Html.BeginForm("Crear", "Usuario", FormMethod.Post, new { @id = "FormRegistro" }))
        {
            <div class="row">
                <div class="col-md-6 form-group">
                    <label>Identificación</label>
                    @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control no-transform" })
                    @Html.ValidationMessageFor(m => m.Identificacion, "", new { @class = "text-danger-form" })
                </div>

                <div class="col-md-6 form-group">
                    <label>Nombre Completo</label>
                    @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control no-transform" })
                    @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger-form" })
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 form-group">
                    <label>Correo Electrónico</label>
                    @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control no-transform", type = "email" })
                    @Html.ValidationMessageFor(m => m.CorreoElectronico, "", new { @class = "text-danger-form" })
                </div>

                <div class="col-md-6 form-group">
                    <label>Contraseña</label>
                    @Html.PasswordFor(m => m.Contrasenna, new { @class = "form-control no-transform" })
                    @Html.ValidationMessageFor(m => m.Contrasenna, "", new { @class = "text-danger-form" })
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 form-group">
                    <label>Teléfono</label>
                    @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control no-transform" })
                    @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger-form" })
                </div>

                <div class="col-md-6 form-group">
                    <label>Rol de Usuario</label>
                    @Html.DropDownListFor(m => m.ConsecutivoRol,
                        (IEnumerable<SelectListItem>)ViewBag.Roles,
                        "-- Seleccione un Rol --",
                        new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.ConsecutivoRol, "", new { @class = "text-danger-form" })
                </div>
            </div>

            <div class="form-group mt-3">
                <label>Dirección Física</label>
                @Html.TextAreaFor(m => m.Direccion, new { @class = "form-control no-transform", rows = "2" })
                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger-form" })
            </div>

            <br />

            <div class="mt-4">
                <button type="submit" class="btn btn-success">
                    <i class="fa fa-save"></i> Guardar Usuario
                </button>

                <a href="@Url.Action("Index", "Usuario")" class="btn btn-secondary">
                    Volver
                </a>
            </div>
        }
    </div>
</div>
