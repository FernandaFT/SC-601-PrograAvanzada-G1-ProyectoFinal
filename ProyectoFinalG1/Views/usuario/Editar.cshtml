@model ProyectoFinalG1.Models.UsuarioModel

@{
    ViewBag.Title = "Editar Usuario";
}

<div class="container mt-5 mb-5">
    <div class="card shadow p-4">

        <h2>Editar Usuario</h2>

        @using (Html.BeginForm("Editar", "Usuario", FormMethod.Post))
        {
            @Html.HiddenFor(m => m.Consecutivo)

            <div class="form-group">
                <label>Identificación</label>
                @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control no-transform", @readonly = "readonly" })
            </div>

            <div class="form-group">
                <label>Correo Electrónico</label>
                @Html.TextBoxFor(m => m.CorreoElectronico, new { @class = "form-control no-transform", @readonly = "readonly" })
            </div>

            <div class="form-group">
                <label>Nombre</label>
                @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control no-transform" })
                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger-form" })
            </div>

            <div class="form-group">
                <label>Teléfono</label>
                @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control no-transform" })
                @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger-form" })
            </div>

            <div class="form-group">
                <label>Dirección</label>
                @Html.TextBoxFor(m => m.Direccion, new { @class = "form-control no-transform" })
                @Html.ValidationMessageFor(m => m.Direccion, "", new { @class = "text-danger-form" })
            </div>

            <div class="form-group">
                <label>Rol</label>
                @Html.DropDownListFor(m => m.ConsecutivoRol, (IEnumerable<SelectListItem>)ViewBag.Roles, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.ConsecutivoRol, "", new { @class = "text-danger-form" })
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" class="form-control" value="********" readonly />
            </div>

            <button type="submit" class="btn btn-primary mt-3">Actualizar</button>
        }
    </div>
</div>
