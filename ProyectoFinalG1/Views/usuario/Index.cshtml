@model List<ProyectoFinalG1.Models.UsuarioModel>

@{
    ViewBag.Title = "Gestión de Usuarios";
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 1;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Gestión de Usuarios</h2>
        <a href="@Url.Action("Crear", "Usuario")" class="btn btn-primary">
            <i class="fa fa-plus"></i> Crear Nuevo Usuario
        </a>
    </div>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>Consecutivo</th>
                <th>Identificación</th>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Teléfono</th>
                <th>Rol</th>
                <th>Estado</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Consecutivo</td>
                    <td>@u.Identificacion</td>
                    <td>@u.Nombre</td>
                    <td>@u.CorreoElectronico</td>
                    <td>@u.Telefono</td>
                    <td>@u.Descripcion</td>
                    <td>@(u.Estado ? "Activo" : "Inactivo")</td>

                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Editar", "Usuario", new { id = u.Consecutivo })"
                               class="btn btn-warning btn-sm">Editar</a>

                            <a href="@Url.Action("CambiarEstado", "Usuario", new { id = u.Consecutivo })"
                               class="btn @(u.Estado ? "btn-danger" : "btn-success") btn-sm"
                               title="@(u.Estado ? "Inactivar" : "Activar")">
                                <i class="fa @(u.Estado ? "fa-times" : "fa-check")"></i>
                                @(u.Estado ? "Inactivar" : "Activar")
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPaginas > 1)
    {
        <nav aria-label="Paginación de usuarios">
            <ul class="pagination justify-content-center">

                <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Usuario", new { pagina = paginaActual - 1 })">
                        Anterior
                    </a>
                </li>

                @for (int i = 1; i <= totalPaginas; i++)
                {
                    <li class="page-item @(i == paginaActual ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Usuario", new { pagina = i })">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", "Usuario", new { pagina = paginaActual + 1 })">
                        Siguiente
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>